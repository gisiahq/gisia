%p{style: "margin:0 0 6px;font-size:15px;color:#4b5563;line-height:1.6;"}
  = @author.name
  submitted a review on merge request
  %a{href: @target_url, style: "color:#1e2a4a;font-weight:600;text-decoration:none;"}
    = "#{@merge_request.class.reference_prefix}#{@merge_request.iid}"

- if @summary_note
  %p{style: "margin:0 0 16px;font-size:14px;color:#374151;line-height:1.7;border-left:3px solid #e5e7eb;padding-left:12px;"}= @summary_note.note

- @notes.each do |note|
  %div{style: "margin:0 0 16px;"}
    - if note.diff_note? && note.position
      %p{style: "margin:0 0 4px;font-size:12px;color:#6b7280;font-family:monospace;"}
        = note.position.new_path
        - if note.position.new_line
          = "line #{note.position.new_line}"
    %p{style: "margin:0;font-size:14px;color:#374151;line-height:1.7;border-left:3px solid #e5e7eb;padding-left:12px;"}= note.note

%table{width: "100%", cellpadding: "0", cellspacing: "0", border: "0", style: "margin-top:8px;"}
  %tr
    %td{align: "center"}
      %a{href: @target_url, style: "display:inline-block;padding:11px 28px;background-color:#4a5e82;color:#ffffff;font-size:14px;font-weight:600;text-decoration:none;border-radius:6px;"} View Review
