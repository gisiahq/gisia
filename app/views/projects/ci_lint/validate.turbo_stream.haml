= turbo_stream.update 'ci-lint-result' do
  - if @result.valid?
    %div{ class: 'px-4 py-3 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm font-medium' }
      = _('CI configuration is valid.')
    - if @result.warnings.any?
      %div{ class: 'mt-3 px-4 py-3 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-800 text-sm' }
        %div{ class: 'font-medium mb-1' }= _('Warnings')
        %ul{ class: 'list-disc list-inside space-y-1' }
          - @result.warnings.each do |w|
            %li= w
  - else
    %div{ class: 'px-4 py-3 rounded-lg bg-rose-50 border border-rose-200 text-rose-800 text-sm' }
      %div{ class: 'font-medium mb-1' }= _('CI configuration is invalid.')
      - if @result.errors.any?
        %ul{ class: 'list-disc list-inside space-y-1' }
          - @result.errors.each do |e|
            %li= e
