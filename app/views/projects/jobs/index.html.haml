- content_for :breadcrumb do
  - nodes = [*project_breadcrumb_nodes(@project), { label: 'Jobs', path: namespace_project_jobs_path(@project.namespace.parent.full_path, @project.namespace.path) }]
  = render 'shared/breadcrumb', nodes: nodes

%div{class: 'w-full bg-white p-6'}
  %div{class: 'w-full max-w-6xl mx-auto flex flex-col px-4'}

    %div{class: 'flex justify-between items-center mb-6'}
      %div
        %h1{class: 'text-2xl font-semibold text-gray-800'}
          = _('Jobs for Project:')
          = @project.name

    = render 'shared/filters/jobs_filters',
      url: namespace_project_jobs_path(@project.namespace.parent.full_path, @project.namespace.path),
      clear_url: namespace_project_jobs_path(@project.namespace.parent.full_path, @project.namespace.path),
      statuses: @statuses
    %div{id: 'jobs-list', class: 'space-y-4'}
      = render 'projects/pipelines/jobs'

      = render 'shared/pagination', collection: @jobs, url_params: @pagination_params, turbo_frame: nil if respond_to?(:render)
