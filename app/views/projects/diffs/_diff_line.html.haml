- line_bg = line[:type] == 'addition' ? 'bg-emerald-100' : line[:type] == 'deletion' ? 'bg-rose-100' : 'bg-gray-50'
- content_bg = line[:type] == 'addition' ? 'bg-emerald-50' : line[:type] == 'deletion' ? 'bg-rose-50' : 'bg-white'
%div{ class: "flex items-stretch min-h-5 group relative", id: line[:line_code], data: { line_code: line[:line_code], diff_line: true } }
  - if @merge_request && line_discussable?(line)
    %button{ class: 'absolute left-2 top-1/2 transform -translate-y-1/2 z-10 p-1 bg-white border border-gray-300 rounded-sm shadow-sm cursor-pointer opacity-0 group-hover:opacity-100 text-gray-500 w-6 h-6 flex items-center justify-center hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300', title: 'Add comment', id: "comment-button-#{line[:line_code]}", data: { line_code: line[:line_code], line_type: line[:type] } }
      = icon 'chat-circle', class: 'w-3 h-3'
  %div{ class: "flex #{line_bg} hover:!bg-blue-50", data: { line_gutter: true } }
    %div{ class: "w-10 border-r border-gray-300 flex-shrink-0" }
      - if line[:old_line].present?
        %div{ class: 'px-1 text-right text-gray-600 text-sm leading-5 select-none h-5 flex items-center justify-end' }= line[:old_line]
      - else
        %div{ class: "h-5" }
    %div{ class: "w-10 border-r border-gray-300 flex-shrink-0" }
      - if line[:new_line].present?
        %div{ class: 'px-1 text-right text-gray-600 text-sm leading-5 select-none h-5 flex items-center justify-end' }= line[:new_line]
      - else
        %div{ class: "h-5" }
  %div{ class: "flex-1 px-2 leading-5 #{content_bg}" }
    %span{ class: 'block whitespace-pre-wrap break-words font-mono text-sm leading-5' }= line[:rich_text].html_safe

- if @merge_request && @grouped_diff_discussions
  - line_notes = @grouped_diff_discussions[line[:line_code]]
  - if line_notes.present?
    %ul.notes-list{ class: "space-y-4 mt-4" }
      - line_notes.each do |note|
        = render partial: 'shared/notes/note', locals: { note: note, draft_reply: true, draft_replies: @grouped_draft_replies && @grouped_draft_replies[note.id] }

- if @merge_request && @grouped_draft_notes
  - line_drafts = @grouped_draft_notes[line[:line_code]]
  - if line_drafts.present?
    %ul.notes-list{ class: "space-y-4 mt-4", id: "drafts-list-#{line[:line_code]}" }
      - line_drafts.each do |draft|
        = render partial: 'shared/notes/draft_note', locals: { draft_note: draft }
