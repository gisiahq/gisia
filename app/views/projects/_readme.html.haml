- if @readme_blob&.data.present?
  %div{ id: 'readme', class: 'bg-white border border-slate-200 rounded-lg overflow-hidden mt-4' }
    %div{ class: 'bg-slate-50 border-b border-slate-200 px-4 py-3 flex items-center gap-2' }
      = icon 'book-open', class: 'w-4 h-4 text-slate-500'
      %span{ class: 'text-sm font-medium text-slate-700' }= @readme_blob.name
    %div{ class: 'px-6 py-5 markdown' }
      = markup(@readme_blob.name, @readme_blob.data, { project: @project, ref: @ref, requested_path: @path }).html_safe
