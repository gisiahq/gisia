- content_for :breadcrumb do
  - nodes = [*project_breadcrumb_nodes(@project), { label: 'Merge Request', path: merge_requests_path(@project) }, { label: "##{@merge_request.id}", path: merge_request_path(@merge_request)}]
  = render 'shared/breadcrumb', nodes: nodes

- content_for :mr_content do
  %div{ class: 'w-full space-y-6 mt-8' }
    %div{ class: 'flex justify-between items-center' }
      %h3{ class: 'text-lg font-semibold text-gray-800' } Pipelines
      - if current_user&.can?(:create_pipeline, @project) && @merge_request.open?
        = button_to run_pipeline_namespace_project_merge_request_path(@project.namespace.parent.full_path, @project.path, @merge_request.iid),
          method: :post,
          class: 'inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer' do
          = icon 'play', class: 'w-4 h-4'
          = _('Run pipeline')
    = render 'projects/pipelines/pipelines'
= render 'detail'
