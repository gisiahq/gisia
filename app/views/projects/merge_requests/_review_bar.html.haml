- draft_count = local_assigns.fetch(:draft_count)
- target_project = merge_request.target_project
%div{ id: 'review-bar', class: "fixed bottom-0 left-64 right-0 z-30 bg-white border-t border-slate-200 shadow-lg #{'hidden' if draft_count.zero?}", data: { controller: 'review-bar' } }
  %div{ class: 'max-w-6xl mx-auto px-6 py-3', data: { controller: 'reply-form' } }
    = form_with url: publish_draft_notes_path(merge_request), method: :post, local: true, id: 'review-publish-form' do |f|
      %div{ class: 'hidden mb-3', data: { "reply-form-target": "editor" } }
        = render 'shared/markdown_editor', f: f, field: :note, placeholder: _('Summary comment (optional)'), min_height: 'min-h-24', initial_content: '', textarea_id: 'editor-review-summary', upload_url: namespace_project_uploads_path(target_project.namespace.parent.full_path, target_project.path), upload_prefix: "/-/project/#{target_project.id}"

    %div{ class: 'flex items-center justify-between gap-4' }
      %span{ id: 'review-bar-count', class: 'text-sm font-medium text-slate-700 whitespace-nowrap' }
        = n_('%{count} pending comment', '%{count} pending comments', draft_count) % { count: draft_count }
      %div{ class: 'flex-1 border border-slate-200 rounded-lg px-3 py-2 text-sm text-slate-400 cursor-text bg-white', data: { "reply-form-target": "placeholder", action: "click->reply-form#expand" } }
        = _('Summary comment (optional)')
      %div{ class: 'flex items-center gap-2' }
        = button_to _('Discard'), discard_draft_notes_path(merge_request), method: :delete, class: 'px-4 py-2 text-sm text-slate-600 hover:text-slate-800 cursor-pointer', form_class: 'inline', form: { data: { turbo_confirm: _('Are you sure you want to discard all pending comments?') } }
        %button{ type: 'submit', form: 'review-publish-form', class: 'px-4 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700 cursor-pointer' }= _('Submit review')
