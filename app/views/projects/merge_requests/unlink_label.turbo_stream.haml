= turbo_stream.replace "merge_request-labels" do
  = render 'shared/labels/selected_labels_turbo', resource: @merge_request, resource_type: 'merge_request', labels: @merge_request.labels, selected_label_ids: @merge_request.label_ids.join(','), can_edit: current_user&.can?(:update_merge_request, @merge_request)

= turbo_stream.replace "label-dropdown-options" do
  = render 'shared/labels/label_dropdown_options', labels: [], selected_ids: @merge_request.label_ids
