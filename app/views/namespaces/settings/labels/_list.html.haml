- if @labels.any?
  %div{class: 'space-y-3'}
    - @labels.each do |label|
      = render 'label', label: label
- else
  %div{class: 'text-center py-12 border border-gray-200 rounded-lg bg-gray-50'}
    = icon 'tag', class: 'w-12 h-12 text-gray-400 mx-auto mb-4'
    %p{class: 'text-gray-600'}
      No labels yet. Create your first label to get started.
