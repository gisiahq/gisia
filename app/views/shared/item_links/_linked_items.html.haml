- can_read_confidential = Ability.allowed?(current_user, :read_confidential_issues, @project)
- link_records = resource.item_link_records.includes(:target).select { |l| !l.target.is_a?(Issue) || !l.target.confidential? || can_read_confidential }

%div{ id: 'linked-items-section', class: 'mt-6 mb-6', data: { controller: 'link-item-form', action: 'click@document->link-item-form#handleClickOutside' } }
  %div{ class: 'flex items-center gap-2 mb-3' }
    %h2{ class: 'text-lg font-semibold text-slate-900' }
      Linked items
    - if current_user
      %button{ type: 'button', class: 'inline-flex items-center px-1.5 py-1 text-slate-500 border border-slate-300 rounded hover:bg-slate-50', data: { action: 'click->link-item-form#toggleForm' } }
        = icon 'plus', class: 'w-3 h-3'

  %div{ id: 'linked-items-container', class: "#{link_records.empty? ? 'hidden ' : ''}border border-slate-200 rounded-lg divide-y divide-slate-200", data: { 'link-item-form-target': 'container' } }
    %div{ class: 'hidden px-3 py-2.5', data: { 'link-item-form-target': 'form' } }
      = form_with url: search_url, method: :post, class: 'hidden', data: { 'link-item-form-target': 'searchForm' } do |f|
        = f.hidden_field :q, value: '', data: { 'link-item-form-target': 'searchQuery' }
      = form_with url: create_url, method: :post, class: 'flex gap-2 items-center relative', data: { 'link-item-form-target': 'createForm' } do |f|
        = f.hidden_field :reference, value: '', data: { 'link-item-form-target': 'referenceInput' }
        %div{ class: 'flex-1 relative' }
          %input{ type: 'text', placeholder: '#123 or !456 or search by title...', class: 'w-full px-3 py-1.5 text-sm border border-slate-300 rounded focus:outline-none focus:ring-1 focus:ring-blue-500', data: { 'link-item-form-target': 'input', action: 'input->link-item-form#search keydown.enter->link-item-form#submitForm' }, autocomplete: 'off' }
          %div{ id: 'link-item-search-results', class: 'absolute top-full left-0 right-0 mt-1 z-10 bg-white border border-slate-200 rounded-lg max-h-48 overflow-y-auto hidden', data: { 'link-item-form-target': 'searchResults' } }
        %button{ type: 'button', class: 'inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 border border-blue-300 rounded hover:bg-blue-100 flex-shrink-0', data: { action: 'click->link-item-form#submitForm' } }
          Add
        %button{ type: 'button', class: 'inline-flex items-center px-2 py-1.5 text-xs font-medium text-slate-600 border border-slate-300 rounded hover:bg-slate-100 flex-shrink-0', data: { action: 'click->link-item-form#hideForm' } }
          Cancel

    %div{ id: 'linked-items-list', data: { 'link-item-form-target': 'list' } }
      - link_records.each do |link|
        = render 'shared/item_links/linked_item', item_link: link
