- content_for :breadcrumb do
  - nodes = [{ label: _('Admin'), path: admin_root_path }, { label: _('Users'), path: admin_users_path }, { label: @user.username, path: admin_user_path(@user) }, { label: _('Edit'), path: '#' }]
  = render 'shared/breadcrumb', nodes: nodes

%div{class: 'w-full bg-white p-2 rounded-lg'}
  %div{class: 'w-full max-w-6xl mx-auto'}

    %div{class: 'py-6'}
      %div{class: 'flex items-center gap-4 mb-6'}
        %div{class: 'h-16 w-16 rounded-full bg-green-500 flex items-center justify-center text-white text-xl font-bold'}
          = @user.username.first.upcase
        %div
          %h1{class: 'text-2xl font-bold text-gray-900'}= format(_('Edit %{username}'), username: @user.username)
          %p{class: 'text-gray-600'}= _('Update user information and permissions')
          - case @user.state
          - when 'active'
            %span{class: 'inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700'}
              = icon 'check-circle', class: 'w-3 h-3'
              = _('Active')
          - when 'banned'
            %span{class: 'inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700'}
              = icon 'prohibit', class: 'w-3 h-3'
              = _('Banned')
          - else
            %span{class: 'inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700'}
              = icon 'prohibit', class: 'w-3 h-3'
              = _('Blocked')

    = form_with model: [:admin, @user], local: true do |f|
      %div{class: 'bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6'}
        %h3{class: 'text-lg font-semibold text-gray-900 mb-6'}= _('Basic Information')

        %div{class: 'grid grid-cols-1 md:grid-cols-2 gap-6'}
          %div
            = f.label :username, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'at', class: 'w-4 h-4 text-green-500'
              = _('Username')
            = f.text_field :username, disabled: true, class: 'w-full px-3 py-2 border border-gray-200 rounded-lg bg-gray-100 text-gray-500 cursor-not-allowed'

          %div
            = f.label :email, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'envelope', class: 'w-4 h-4 text-blue-500'
              = _('Email')
            = f.email_field :email, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent'
            - if @user.errors[:email].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:email].first

        %div{class: 'mt-6'}
          = f.label :name, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
            = icon 'user', class: 'w-4 h-4 text-purple-500'
            = _('Full Name')
          = f.text_field :name, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent'
          - if @user.errors[:name].any?
            %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:name].first

      %div{class: 'bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6'}
        %h3{class: 'text-lg font-semibold text-gray-900 mb-6'}= _('Password')

        %div{class: 'grid grid-cols-1 md:grid-cols-2 gap-6'}
          %div
            = f.label :password, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'lock', class: 'w-4 h-4 text-indigo-500'
              = _('Password')
            = f.password_field :password, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: _('Leave blank to keep current password')
            - if @user.errors[:password].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:password].first

          %div
            = f.label :password_confirmation, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'lock', class: 'w-4 h-4 text-indigo-500'
              = _('Password confirmation')
            = f.password_field :password_confirmation, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: _('Confirm new password')
            - if @user.errors[:password_confirmation].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:password_confirmation].first

        %p{class: 'text-xs text-gray-500 mt-2'}= _('Leave password fields blank to keep the current password')

      %div{class: 'bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6'}
        %h3{class: 'text-lg font-semibold text-gray-900 mb-6'}= _('Permissions & Status')

        %div{class: 'flex items-center'}
          = f.check_box :admin, class: 'h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded'
          = f.label :admin, class: 'ml-2 block text-sm text-gray-900' do
            = _('Administrator')
          %p{class: 'ml-6 text-xs text-gray-500'}= _('Grants full access to the admin area')

      %div{class: 'flex items-center justify-between'}
        %div{class: 'flex items-center gap-3'}
          = f.submit _('Update User'), class: 'inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-all duration-200'
          = link_to admin_user_path(@user), class: 'inline-flex items-center gap-2 px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-300 transition-all duration-200' do
            = _('Cancel')

        - if @user.blocked?
          = link_to unblock_admin_user_path(@user), data: { turbo_method: :post }, class: 'inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition-all duration-200' do
            = icon 'user-check', class: 'w-4 h-4'
            = _('Unblock User')
        - else
          = link_to block_admin_user_path(@user), data: { turbo_method: :post, turbo_confirm: _('Are you sure you want to block this user?') }, class: 'inline-flex items-center gap-2 px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-all duration-200' do
            = icon 'prohibit', class: 'w-4 h-4'
            = _('Block User')
