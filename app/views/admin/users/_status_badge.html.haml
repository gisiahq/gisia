- case user.state
- when 'active'
  %span{ id: 'user-status', class: 'inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700' }
    = icon 'check-circle', class: 'w-3 h-3'
    = _('Active')
- when 'banned'
  %span{ id: 'user-status', class: 'inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700' }
    = icon 'prohibit', class: 'w-3 h-3'
    = _('Banned')
- else
  %span{ id: 'user-status', class: 'inline-flex items-center gap-1 mt-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700' }
    = icon 'prohibit', class: 'w-3 h-3'
    = _('Blocked')
