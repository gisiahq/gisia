- content_for :breadcrumb do
  - nodes = [{ label: _('Admin'), path: admin_root_path }, { label: _('Users'), path: admin_users_path }, { label: _('New User'), path: '#' }]
  = render 'shared/breadcrumb', nodes: nodes

%div{class: 'w-full bg-white p-2 rounded-lg'}
  %div{class: 'w-full max-w-6xl mx-auto'}

    %div{class: 'py-6'}
      %h1{class: 'text-2xl font-bold text-gray-900 mb-2'}= _('New User')

    %p{class: 'text-gray-600 mb-6'}= _('Create a new user account')

    = form_with model: [:admin, @user], local: true do |f|
      %div{class: 'bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6'}
        %h3{class: 'text-lg font-semibold text-gray-900 mb-6'}= _('Basic Information')

        %div{class: 'grid grid-cols-1 md:grid-cols-2 gap-6 mb-4'}
          %div
            = f.label :username, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'at', class: 'w-4 h-4 text-green-500'
              = _('Username')
            = f.text_field :username, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: 'johndoe'
            - if @user.errors[:username].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:username].first

          %div
            = f.label :email, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'envelope', class: 'w-4 h-4 text-blue-500'
              = _('Email')
            = f.email_field :email, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: 'john@example.com'
            - if @user.errors[:email].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:email].first

        %div{class: 'mb-4'}
          = f.label :name, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
            = icon 'user', class: 'w-4 h-4 text-purple-500'
            = _('Full Name')
          = f.text_field :name, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: 'John Doe'
          - if @user.errors[:name].any?
            %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:name].first

      %div{class: 'bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6'}
        %h3{class: 'text-lg font-semibold text-gray-900 mb-6'}= _('Permissions & Status')

        %div{class: 'flex items-center mb-4'}
          = f.check_box :admin, class: 'h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded'
          = f.label :admin, _('Administrator'), class: 'ml-2 block text-sm text-gray-900'
          %p{class: 'ml-6 text-xs text-gray-500'}= _('Grants full access to the admin area')

      %div{class: 'bg-gray-50 border border-gray-200 rounded-lg p-6 mb-6'}
        %h3{class: 'text-lg font-semibold text-gray-900 mb-6'}= _('Password')

        %div{class: 'grid grid-cols-1 md:grid-cols-2 gap-6'}
          %div
            = f.label :password, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'lock', class: 'w-4 h-4 text-indigo-500'
              = _('Password')
            = f.password_field :password, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', autocomplete: 'new-password'
            - if @user.errors[:password].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:password].first

          %div
            = f.label :password_confirmation, class: 'flex items-center gap-2 text-sm font-medium text-gray-700 mb-2' do
              = icon 'lock', class: 'w-4 h-4 text-indigo-500'
              = _('Password confirmation')
            = f.password_field :password_confirmation, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', autocomplete: 'new-password'
            - if @user.errors[:password_confirmation].any?
              %p{class: 'mt-1 text-sm text-red-600'}= @user.errors[:password_confirmation].first

      %div{class: 'flex items-center gap-3'}
        = f.submit _('Create User'), class: 'inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-all duration-200'
        = link_to _('Cancel'), admin_users_path, class: 'inline-flex items-center gap-2 px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-300 transition-all duration-200'
