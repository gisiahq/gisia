- if errors.any?
  %div{ class: 'bg-red-50 border border-red-200 rounded-lg p-4 mb-6' }
    %h3{ class: 'text-sm font-medium text-red-800 mb-2' }= _('Please fix the following errors:')
    %ul{ class: 'space-y-1 text-sm text-red-700' }
      - errors.group_by(&:attribute).each do |attr, attr_errors|
        %li
          %span{ class: 'font-medium' }= attr.to_s.humanize
          = ": #{attr_errors.map(&:message).join(', ')}"
